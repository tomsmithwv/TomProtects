---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';

const platforms = ['Stripe', 'Kit', 'Kajabi', 'Circle', 'Teachable', 'Shopify', 'Other'];
---

<BaseLayout
  title="Start your review — TomProtects"
  description="Tell me about your domain and the platforms you run on. I'll confirm scope and next steps for your Domain & Deliverability Review."
>
  <section class="mx-auto max-w-2xl px-4 py-16">
    <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">Domain &amp; Deliverability Review</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">Start your review</h1>
    <p class="mt-4 text-ink/70">
      Tell me where things stand and I'll confirm scope, price, and next steps. Async by default — payment is
      collected only after scope is agreed. Launch price <strong>$297</strong>.
    </p>

    <form id="audit-form" class="mt-10 space-y-5" novalidate>
      <div>
        <label for="name" class="block text-sm font-medium">Name</label>
        <input id="name" name="name" type="text" autocomplete="name"
          class="mt-1 w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-ink focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium">Email <span class="text-fail">*</span></label>
        <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@yourdomain.com"
          class="mt-1 w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-ink placeholder-ink/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
      </div>

      <div>
        <label for="domain" class="block text-sm font-medium">Primary domain <span class="text-fail">*</span></label>
        <input id="domain" name="domain" type="text" required placeholder="yourbrand.com"
          class="mt-1 w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-ink placeholder-ink/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30" />
      </div>

      <div>
        <span class="block text-sm font-medium">Platforms you run on</span>
        <div class="mt-2 flex flex-wrap gap-2">
          {platforms.map((p) => (
            <label class="cursor-pointer rounded-lg border border-black/15 bg-white px-3 py-1.5 text-sm has-[:checked]:border-accent has-[:checked]:bg-accent/10">
              <input type="checkbox" name="platforms" value={p} class="sr-only" />
              {p}
            </label>
          ))}
        </div>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium">Anything else I should know?</label>
        <textarea id="message" name="message" rows="4" placeholder="Recent issues, concerns, deadlines…"
          class="mt-1 w-full rounded-lg border border-black/15 bg-white px-4 py-3 text-ink placeholder-ink/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"></textarea>
      </div>

      <button id="audit-submit" type="submit"
        class="w-full rounded-lg bg-accent px-7 py-4 text-lg font-semibold text-white transition hover:opacity-90 disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto">
        Request my review
      </button>

      <p id="audit-status" class="text-sm" role="status" aria-live="polite"></p>
    </form>

    <div id="audit-success" class="mt-10 hidden rounded-2xl border border-black/10 bg-white p-8 text-center">
      <p class="text-2xl font-semibold">Got it — thank you.</p>
      <p class="mt-3 text-ink/70">
        I'll review what you sent and reply within 1–2 business days with scope, price, and next steps. Check your
        inbox (and spam, just in case).
      </p>
      <p class="mt-6"><a href="/" class="font-medium text-accent">← Back home</a></p>
    </div>
  </section>

  <script>
    const form = document.getElementById('audit-form') as HTMLFormElement | null;
    const btn = document.getElementById('audit-submit') as HTMLButtonElement;
    const status = document.getElementById('audit-status')!;
    const success = document.getElementById('audit-success')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = new FormData(form);
      const email = String(data.get('email') || '').trim();
      const domain = String(data.get('domain') || '').trim();
      if (!email || !domain) {
        status.textContent = 'Please add your email and primary domain.';
        status.style.color = '#991b1b';
        return;
      }

      btn.disabled = true;
      const prev = btn.textContent;
      btn.textContent = 'Sending…';
      status.textContent = '';

      try {
        const res = await fetch('/api/audit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name: data.get('name') || '',
            email,
            domain,
            platforms: data.getAll('platforms'),
            message: data.get('message') || '',
          }),
        });
        const json = await res.json();
        if (!res.ok) throw new Error(json.error || 'Something went wrong. Please try again.');
        form.classList.add('hidden');
        success.classList.remove('hidden');
        success.scrollIntoView({ behavior: 'smooth', block: 'center' });
      } catch (err) {
        status.textContent = err instanceof Error ? err.message : 'An error occurred. Please try again.';
        status.style.color = '#991b1b';
        btn.disabled = false;
        btn.textContent = prev;
      }
    });
  </script>
</BaseLayout>
