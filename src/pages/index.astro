---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import CheckerWidget from '../components/CheckerWidget.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import FounderPhoto from '../components/FounderPhoto.astro';

// ╔══════════════════════════════════════════════════════════════════════════╗
// ║  PRICING — set your numbers here. This is the only place to edit prices.  ║
// ╚══════════════════════════════════════════════════════════════════════════╝
const pricing = {
  launchPrice: '$297', //  ← current LIVE launch price (the big number)
  nextPrice: '$497', //    ← the next tier it steps up to (runway). Set '' to hide the runway line.
  standardPrice: 'standard', // ← eventual standard price/label, e.g. '$997' or 'standard rate'
  unit: 'one-time', //     ← billing note shown beside the price
};

// What's included at this price (from the brief).
const priceIncludes = [
  'Full domain & deliverability report',
  'SPF / DKIM / DMARC review',
  'Registrar security review',
  'Prioritized fix list with specific values',
  'Optional intro + walkthrough calls',
  '30-day follow-up',
];

const findings = [
  { sev: 'high', title: 'No 2FA on the domain registrar', body: 'The single account that controls your domain — and therefore your email and website — protected by a password alone.' },
  { sev: 'high', title: 'A reused, breached password', body: 'The login for a critical account found in a known data breach and reused elsewhere. One of the most common ways businesses get taken over.' },
  { sev: 'high', title: 'Shared registrar / hosting login', body: 'One set of credentials handed to a VA or contractor, never rotated, with full control of your domain.' },
  { sev: 'med', title: 'DMARC set to p=none (or missing)', body: 'Anyone can spoof your domain and email your customers as you. No enforcement, no reporting.' },
  { sev: 'med', title: 'Personal details exposed in WHOIS', body: 'Home address and phone number published in public domain records because privacy was never switched on.' },
  { sev: 'med', title: 'A forgotten subdomain pointing nowhere', body: 'An old subdomain still aimed at a service you stopped using — a quiet takeover risk most owners never see.' },
];

const reality = [
  { icon: '🔑', title: 'Email is the master key', body: 'Every password reset — your bank, Stripe, your course platform — flows through your inbox. Lose control of email and an attacker can walk into everything else.' },
  { icon: '🌐', title: 'Your domain is your identity', body: 'Your domain is your brand, your email, and your reputation. If it lapses or gets hijacked, the business behind it goes dark with it.' },
  { icon: '💳', title: 'Revenue platforms are targets', body: 'Stripe, Kit, Kajabi, Circle — the tools you get paid through are exactly what attackers go after. They follow the money, and the money runs through your stack.' },
];

const audience = [
  { icon: '✍️', title: 'Creators', body: 'You sell courses, memberships, or a paid newsletter, and your audience trusts your name.' },
  { icon: '🧭', title: 'Consultants', body: 'Your reputation is the product. A spoofed email or hijacked domain hits where it hurts most.' },
  { icon: '🛒', title: 'Online business owners', body: 'You run on Stripe, Kit, Kajabi, and Circle — and a gap in any one of them puts revenue at risk.' },
];

const steps = [
  { n: '1', title: 'Start with the form or a call', body: 'Tell me your domain and the platforms you run on. Prefer to talk it through first? A short intro call is optional.' },
  { n: '2', title: 'I review and report', body: 'I dig into your domain, email auth, registrar, WHOIS, and subdomains, then write it up in plain English — typically 5–7 business days.' },
  { n: '3', title: 'Walkthrough or async', body: 'We review the findings on a call, or you take the written report and work through it at your own pace. Your choice.' },
];

const deliverables = [
  'A written report in plain English — every finding, prioritized',
  'Full DNS review',
  'Email authentication: SPF, DKIM, DMARC',
  'Registrar security review',
  'WHOIS / privacy exposure check',
  'Subdomain inventory',
  'A prioritized action list with exact values to change',
];
---

<BaseLayout
  title="TomProtects — Protect the business behind the brand"
  description="Security reviews for online businesses. Start with a free check of your domain's email authentication — SPF, DKIM, and DMARC — then get the full review."
>
  <!-- 1–2. Hero with the live checker (primary CTA) + inline result -->
  <section class="border-b border-black/5 bg-gradient-to-b from-white to-cream">
    <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-24">
      <p class="mb-4 text-xs font-bold uppercase tracking-[0.14em] text-accent">Free email security check</p>
      <h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-5xl">Protect the business behind the brand</h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-ink/70 sm:text-xl">
        Start with a free check of your domain's email authentication — SPF, DKIM, and DMARC.
        Get a grade and the exact gaps, in plain English.
      </p>

      <div class="mt-10">
        <CheckerWidget />
      </div>

      <p class="mt-4 text-sm">
        <a href="/#how-it-works" class="text-accent underline-offset-4 hover:underline">See how it works →</a>
      </p>
    </div>
  </section>

  <!-- 3. Sample Audit Findings -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">Sample audit findings</p>
      <h2 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">
        The free check covers email. The full audit goes much deeper.
      </h2>
      <p class="mt-4 max-w-2xl text-ink/70">
        Here's the kind of thing a real review surfaces — the gaps you can't see from a DNS lookup alone:
      </p>

      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {findings.map((f) => (
          <div class="rounded-xl border border-black/10 bg-cream p-5">
            <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-bold uppercase tracking-wide ${f.sev === 'high' ? 'bg-fail/15 text-[#991b1b]' : 'bg-warn/20 text-[#92400e]'}`}>
              {f.sev === 'high' ? 'High risk' : 'Needs attention'}
            </span>
            <h3 class="mt-3 font-semibold">{f.title}</h3>
            <p class="mt-1.5 text-sm text-ink/70">{f.body}</p>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <a href="/audit" class="inline-block rounded-lg bg-accent px-7 py-3.5 font-semibold text-white transition hover:opacity-90">
          See what your audit surfaces →
        </a>
      </div>
    </div>
  </section>

  <!-- 4. The Reality -->
  <section class="bg-ink text-cream">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <p class="text-center text-xs font-bold uppercase tracking-[0.14em] text-accent-dark">The reality</p>
      <h2 class="mx-auto mt-2 max-w-2xl text-center text-3xl font-bold tracking-tight sm:text-4xl">
        Three things attackers already know about your business
      </h2>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {reality.map((r) => (
          <div>
            <p class="text-4xl" aria-hidden="true">{r.icon}</p>
            <h3 class="mt-4 text-xl font-semibold">{r.title}</h3>
            <p class="mt-2 text-cream/70">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Who This Is For -->
  <section class="bg-cream">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">Who this is for</p>
      <h2 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">Built for the people who earn through their audience</h2>
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        {audience.map((a) => (
          <div class="rounded-xl border border-black/10 bg-white p-6">
            <p class="text-2xl" aria-hidden="true">{a.icon}</p>
            <h3 class="mt-3 text-lg font-semibold">{a.title}</h3>
            <p class="mt-2 text-sm text-ink/70">{a.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. How It Works -->
  <section id="how-it-works" class="scroll-mt-20 bg-white">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">How it works</p>
      <h2 class="mt-2 max-w-2xl text-3xl font-bold tracking-tight sm:text-4xl">Async by default. Calls optional, both ends.</h2>
      <div class="mt-10 grid gap-8 md:grid-cols-3">
        {steps.map((s) => (
          <div class="relative rounded-xl border border-black/10 bg-cream p-6">
            <span class="flex h-10 w-10 items-center justify-center rounded-full bg-accent text-lg font-bold text-white">{s.n}</span>
            <h3 class="mt-4 text-lg font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm text-ink/70">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. What You Get -->
  <section class="bg-cream">
    <div class="mx-auto max-w-3xl px-4 py-20">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">What you get</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">A complete picture — and an exact list of what to fix</h2>
      <ul class="mt-8 space-y-3">
        {deliverables.map((d) => (
          <li class="flex gap-3">
            <span class="mt-0.5 flex-shrink-0 font-bold text-accent">✓</span>
            <span class="text-ink/80">{d}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- 8. Pricing -->
  <section class="bg-ink text-cream">
    <div class="mx-auto max-w-2xl px-4 py-20 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent-dark">Pricing</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Launch price — going up as spots fill</h2>

      <div class="mx-auto mt-10 max-w-md rounded-2xl border border-white/15 bg-white/5 p-8">
        <p class="text-sm font-medium text-cream/60">Domain &amp; Deliverability Review</p>

        <span class="mt-4 inline-block rounded-full bg-accent-dark/15 px-3 py-1 text-xs font-bold uppercase tracking-wide text-accent-dark">
          Launch price
        </span>
        <p class="mt-3">
          <span class="text-5xl font-bold">{pricing.launchPrice}</span>
          <span class="text-cream/60">{pricing.unit}</span>
        </p>

        {pricing.nextPrice && (
          <p class="mt-3 text-sm font-medium text-accent-dark">
            {pricing.launchPrice} now → {pricing.nextPrice} → {pricing.standardPrice}.
            Spots are limited — the price goes up as they fill.
          </p>
        )}
        <p class="mt-2 text-xs text-cream/50">Early reviews are intentionally underpriced while I build testimonials.</p>

        <ul class="mt-6 space-y-2 text-left text-sm text-cream/80">
          {priceIncludes.map((item) => (
            <li class="flex gap-2"><span class="text-accent-dark">✓</span> {item}</li>
          ))}
        </ul>

        <a href="/audit" class="mt-8 block rounded-lg bg-accent px-7 py-3.5 font-semibold text-white transition hover:opacity-90">
          Start your review
        </a>
        <p class="mt-4 text-xs text-cream/50">
          No retainers. No upsells. Fixed price. Payment is collected after scope is confirmed via the intake form.
        </p>
        <p class="mt-4 text-sm text-cream/80">
          My goal is simple: leave you with more than you paid for. If something in your report isn't clear or
          actionable, tell me — I'll make it right.
        </p>
      </div>
    </div>
  </section>

  <!-- 9. About -->
  <section id="about" class="scroll-mt-20 bg-white">
    <div class="mx-auto max-w-3xl px-4 py-20 text-center">
      <FounderPhoto class="mx-auto h-32 w-32 sm:h-40 sm:w-40" />
      <p class="mt-6 text-xs font-bold uppercase tracking-[0.14em] text-accent">About</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Hi, I'm Tom.</h2>
      <p class="mt-5 text-lg leading-relaxed text-ink/70">
        I've spent 20+ years in IT and cybersecurity — protecting organizations from the same threats that now target
        online businesses. I help creators, consultants, and business owners lock down the domain, email, and platforms
        their livelihood runs on. No jargon, no fear-mongering — just clear, practical fixes.
      </p>
      <p class="mt-6 text-sm font-semibold text-accent">CISSP · CISM · CDPSE · 20+ years</p>
    </div>
  </section>

  <!-- 10. Latest from the newsletter (3 most recent, loaded client-side) -->
  <section class="bg-cream">
    <div class="mx-auto max-w-5xl px-4 py-20">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">From the newsletter</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Latest writing</h2>

      <div id="latest-posts" class="mt-10 grid gap-6 md:grid-cols-3"></div>

      <p class="mt-8">
        <a href="/blog" class="font-medium text-accent underline-offset-4 hover:underline">Read the blog →</a>
      </p>
    </div>
  </section>

  <!-- 11. Final CTA + newsletter signup -->
  <section class="bg-ink text-cream">
    <div class="mx-auto max-w-2xl px-4 py-20 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent-dark">Ready when you are</p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight sm:text-4xl">Get practical security tips — and check your domain free</h2>
      <p class="mt-4 text-cream/70">
        Join the newsletter for plain-English security and deliverability tips for online businesses.
      </p>
      <div class="mx-auto mt-8 max-w-md text-left">
        <NewsletterSignup source="source-newsletter" />
      </div>
    </div>
  </section>

  <script>
    // Fill the "Latest from the newsletter" section from /api/posts. Home stays
    // prerendered; this enhances it. On empty/error, the "Read the blog" link remains.
    (async () => {
      const wrap = document.getElementById('latest-posts');
      if (!wrap) return;
      try {
        const res = await fetch('/api/posts');
        if (!res.ok) return;
        const { posts } = await res.json();
        if (!Array.isArray(posts) || posts.length === 0) {
          wrap.innerHTML = `<p style="color:#5c5750;">First issue coming soon. <a href="/blog" style="color:#0f5c4c;font-weight:500;text-decoration:underline;">Subscribe →</a></p>`;
          return;
        }
        const esc = (s: unknown) => String(s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);
        wrap.innerHTML = posts
          .map((p: any) => `
            <a href="/blog/${esc(p.slug)}" style="display:block;background:#fff;border:1px solid rgba(0,0,0,0.1);border-radius:12px;padding:20px;text-decoration:none;color:inherit;">
              <h3 style="font-weight:600;font-size:1.05rem;margin:0;">${esc(p.subject)}</h3>
              ${p.dateLabel ? `<p style="font-size:0.8rem;color:#6b6b6b;margin:6px 0 0;">${esc(p.dateLabel)}</p>` : ''}
              ${p.excerpt ? `<p style="font-size:0.9rem;color:#5c5750;margin:8px 0 0;line-height:1.5;">${esc(p.excerpt)}</p>` : ''}
              <span style="display:inline-block;margin-top:10px;font-size:0.85rem;font-weight:500;color:#0f5c4c;">Read →</span>
            </a>`)
          .join('');
      } catch {
        /* leave the section empty; the Read the blog link still works */
      }
    })();
  </script>
</BaseLayout>
