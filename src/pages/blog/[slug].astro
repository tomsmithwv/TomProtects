---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getPostBySlug } from '../../utils/blog';

const { slug } = Astro.params;
const apiKey = Astro.locals.runtime?.env?.KIT_API_KEY;
const post = apiKey && slug ? await getPostBySlug(apiKey, slug) : null;

// Miss → 404 status; Astro renders src/pages/404.astro for the body.
if (!post) {
  Astro.response.status = 404;
}
---

{post && (
  <BaseLayout
    title={`${post.subject} — TomProtects`}
    description={post.excerpt}
    ogType="article"
    publishedTime={post.date}
  >
    <article class="mx-auto max-w-2xl px-4 py-16">
      <a href="/blog" class="text-sm font-medium text-accent">← All posts</a>
      <h1 class="mt-4 text-4xl font-bold leading-tight tracking-tight">{post.subject}</h1>
      {post.dateLabel && <p class="mt-2 text-sm text-ink/50">{post.dateLabel}</p>}

      <div class="post-content mt-8" set:html={post.content} />

      <hr class="my-12 border-black/10" />

      <!-- Per-post CTA: newsletter signup (source-blog) -->
      <div class="rounded-2xl border border-black/10 bg-white p-8">
        <h3 class="text-xl font-semibold">Get the next one in your inbox</h3>
        <p class="mt-2 text-ink/70">Practical security and deliverability tips for online businesses. No hype.</p>
        <div class="mt-4">
          <NewsletterSignup source="source-blog" />
        </div>
      </div>

      <!-- Per-post CTA: link to the free checker -->
      <p class="mt-8 text-center">
        <a href="/tools" class="font-medium text-accent underline-offset-4 hover:underline">
          Check your domain's email setup — free →
        </a>
      </p>
    </article>
  </BaseLayout>
)}

<style is:global>
  .post-content {
    color: #1a1a1a;
    line-height: 1.75;
    font-size: 1.05rem;
  }
  .post-content p {
    margin: 0 0 1.1em;
  }
  .post-content a {
    color: #0f5c4c;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .post-content h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 1.6em 0 0.5em;
    line-height: 1.2;
  }
  .post-content h3 {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 1.4em 0 0.5em;
  }
  .post-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: 1.2em 0;
  }
  .post-content ul,
  .post-content ol {
    margin: 0 0 1.1em 1.25em;
  }
  .post-content li {
    margin: 0.3em 0;
  }
  .post-content blockquote {
    border-left: 3px solid #0f5c4c;
    padding-left: 1em;
    color: #5c5750;
    margin: 1.2em 0;
  }
</style>
