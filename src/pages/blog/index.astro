---
export const prerender = false;
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import { getPublicBroadcasts } from '../../utils/blog';

// Server-rendered at request time; Kit responses are edge-cached ~1h, so new
// public broadcasts appear within the cache window without a redeploy.
const apiKey = Astro.locals.runtime?.env?.KIT_API_KEY;
const posts = apiKey ? await getPublicBroadcasts(apiKey) : [];
---

<BaseLayout
  title="Blog — TomProtects"
  description="Practical, no-hype security and deliverability guidance for online businesses."
>
  <section class="mx-auto max-w-3xl px-4 py-16">
    <p class="mb-3 text-xs font-bold uppercase tracking-[0.14em] text-accent">From the newsletter</p>
    <h1 class="text-4xl font-bold tracking-tight">Blog</h1>

    {posts.length === 0 ? (
      <div class="mt-10 rounded-2xl border border-black/10 bg-white p-10 text-center">
        <p class="text-2xl font-semibold"><span aria-hidden="true">📬</span> First issue coming soon.</p>
        <p class="mx-auto mt-3 max-w-md text-ink/70">
          Practical security and deliverability tips for online businesses — no hype, no fear-mongering.
          Subscribe to get the first one the moment it lands.
        </p>
        <div class="mx-auto mt-6 max-w-md text-left">
          <NewsletterSignup source="source-blog" />
        </div>
      </div>
    ) : (
      <ul class="mt-10 divide-y divide-black/10">
        {posts.map((p) => (
          <li class="py-6">
            <a href={`/blog/${p.slug}`} class="group block">
              <h2 class="text-2xl font-semibold transition group-hover:text-accent">{p.subject}</h2>
              {p.dateLabel && <p class="mt-1 text-sm text-ink/70">{p.dateLabel}</p>}
              {p.excerpt && <p class="mt-2 text-ink/70">{p.excerpt}</p>}
              <span class="mt-2 inline-block text-sm font-medium text-accent">Read →</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
