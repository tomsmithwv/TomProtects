---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found — TomProtects" description="That page doesn't exist.">
  <section class="mx-auto max-w-2xl px-4 py-24 text-center">
    <p class="text-xs font-bold uppercase tracking-[0.14em] text-accent">404</p>
    <h1 class="mt-3 text-3xl font-bold">Page not found</h1>
    <p class="mt-3 text-ink/70">That page doesn't exist, moved, or isn't public yet.</p>
    <p class="mt-6 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm font-medium text-accent">
      <a href="/" class="hover:underline">Home</a>
      <a href="/blog" class="hover:underline">Blog</a>
      <a href="/tools" class="hover:underline">Free checker</a>
    </p>
  </section>
</BaseLayout>
